# Database
DATABASE_URL=postgresql://user:password@localhost:5432/solar_service_manager

# API Server
PORT=3000

# Security (generate with: openssl rand -hex 32)
SESSION_SECRET=
JWT_SECRET=e738be32ebddd56e414a94d657f25a106565cc6af551050f9e857001e11cb9c2

# CORS — comma-separated list of allowed origins in production
ALLOWED_ORIGINS=http://localhost:5173

# Twilio SMS (optional — omit to run in mock/log-only mode)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890

# Sentry error monitoring (optional — omit to disable)
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/YYYY
# VITE_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/YYYY
# SENTRY_AUTH_TOKEN=sntrys_...   # for source map upload in CI
# SENTRY_ORG=your-org
# SENTRY_PROJECT=solar-api

# Production domain (used by docker-compose Caddy service)
# DOMAIN=admin.greenvolt.in

# PostgreSQL credentials (used by docker-compose postgres service)
# POSTGRES_USER=solar
# POSTGRES_PASSWORD=solar_secret
# POSTGRES_DB=solar_service_manager

# First admin credentials (used by: pnpm --filter @workspace/db run seed-admin)
ADMIN_EMAIL=admin@greenvolt.in
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin
