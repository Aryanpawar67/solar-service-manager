# =============================================================================
#  GreenVolt — Environment Variables
#  Copy this file to .env and fill in the values.
#  Generate secrets with: openssl rand -hex 32
# =============================================================================


# =============================================================================
#  DATABASE  (shared by API server + seed scripts)
# =============================================================================

# Supabase (recommended):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Local Postgres fallback:
# DATABASE_URL=postgresql://solar:solar_secret@localhost:5432/solar_service_manager


# =============================================================================
#  API SERVER  (apps/api-server)
# =============================================================================

PORT=3000
NODE_ENV=development

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:6789

# Twilio SMS (optional — omit to run in log-only / mock mode)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Sentry — API server error monitoring (optional)
SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/YYYY
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=greenvolt-api


# =============================================================================
#  ADMIN DASHBOARD  (apps/admin-dashboard — Vite)
#  Prefix: VITE_
# =============================================================================

# Sentry — admin dashboard error monitoring (optional)
VITE_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/YYYY


# =============================================================================
#  CUSTOMER WEBSITE  (apps/customer-website — Vite)
#  Prefix: VITE_
#  Note: add a VITE_ prefix to any public variable exposed to the browser.
# =============================================================================

# No additional vars required beyond the shared API proxy (configured in vite.config.ts)


# =============================================================================
#  STAFF APP  (apps/staff-app — Expo / React Native)
#  Prefix: EXPO_PUBLIC_  (values are bundled into the app — do not put secrets here)
# =============================================================================

# Base URL of the API server reachable from the device / simulator
# Local dev (same machine):   http://localhost:3000
# Physical device on LAN:     http://192.168.x.x:3000
# Production:                 https://api.greenvolt.in
EXPO_PUBLIC_API_URL=http://localhost:3000

# Sentry — staff app error monitoring (optional)
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/YYYY


# =============================================================================
#  SEED SCRIPTS  (lib/db/scripts)
# =============================================================================

# First admin account — used by: pnpm --filter @workspace/db run seed-admin
ADMIN_EMAIL=admin@greenvolt.in
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# Staff account — used by: pnpm --filter @workspace/db run seed-staff-user
# Login with these credentials in the Staff App (localhost:8081) or Expo Go
STAFF_EMAIL=staff@greenvolt.in
STAFF_PASSWORD=changeme123
STAFF_NAME=Staff Member

# Sample customer account — used by: pnpm --filter @workspace/db run seed-customer-user
CUSTOMER_EMAIL=customer@greenvolt.in
CUSTOMER_PASSWORD=changeme123
CUSTOMER_NAME=Sample Customer
CUSTOMER_ID=1


# =============================================================================
#  DOCKER / PRODUCTION  (docker-compose)
# =============================================================================

# Production domain for Caddy reverse proxy
DOMAIN=admin.greenvolt.in

# Postgres container credentials
POSTGRES_USER=solar
POSTGRES_PASSWORD=solar_secret
POSTGRES_DB=solar_service_manager
