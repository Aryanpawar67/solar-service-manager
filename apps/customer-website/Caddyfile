:80 {
    root * /srv
    encode gzip

    # Proxy /api/* and /uploads/* to the API server.
    # API_INTERNAL_URL defaults to docker-compose service name; override with
    # Railway internal URL e.g. http://api.railway.internal:3000
    reverse_proxy /api/* {$API_INTERNAL_URL:http://api:3000}
    reverse_proxy /uploads/* {$API_INTERNAL_URL:http://api:3000}

    # SPA fallback — all other paths serve index.html
    try_files {path} /index.html
    file_server
}
